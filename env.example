# Audio Pipeline Tester Environment Variables
# Copy this file to .env and fill in your values

# Whisper Model Configuration
WHISPER_MODEL_SIZE=small

# Hugging Face Configuration (for speaker diarization)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_USE_TLS=true

# OAuth2 Email Configuration (Gmail)
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8501

# Optional: Custom model paths
# WHISPER_MODEL_PATH=/path/to/custom/model
# DIARIZATION_MODEL_PATH=/path/to/custom/diarization/model
